# PremiumCare contact form — environment

# Recipient (defaults to bibi@premiumcare.dk if unset)
CONTACT_TO_EMAIL=bibi@premiumcare.dk

# From address shown in the inbox
CONTACT_FROM_EMAIL=no-reply@premiumcare.dk

# Option A — Resend (recommended)
RESEND_API_KEY=

# Option B — SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@premiumcare.dk
